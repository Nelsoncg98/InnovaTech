            "body": {
              "mode": "raw",
              "raw": "{\n  \"clienteId\": \"USER-WEB-888\",\n  \"carrito\": [\n    {\n      \"sku\": \"SKU-LAP-001\",\n      \"cantidad\": 2\n    }\n  ],\n  \"datosPago\": {\n    \"tokenTarjeta\": \"tkn_web_visa\"\n  }\n}"
            },
            "url": {
              "raw": "http://localhost:8087/api/v1/ventas-web/checkout",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8087",
              "path": ["api", "v1", "ventas-web", "checkout"]
            }
          }
        }
