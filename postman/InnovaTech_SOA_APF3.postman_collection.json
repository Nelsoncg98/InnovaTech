{
  "info": {
    "name": "InnovaTech SOA - APF3",
    "description": "Colección oficial de pruebas de integración (Caja Negra) para la arquitectura orientada a servicios de InnovaTech.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. WSO2 Enterprise Service Bus",
      "item": [
        {
          "name": "WSO2 - Proxy POS (XML -> JSON)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/xml",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "<PosOrder>\n    <caja>CAJA-01</caja>\n    <dni>76543210</dni>\n    <sku>SKU-LAP-001</sku>\n    <cantidad>1</cantidad>\n    <monto>3500.0</monto>\n    <token>0000_1234_visa</token>\n</PosOrder>"
            },
            "url": {
              "raw": "http://localhost:8290/wso2/pos/checkout",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8290",
              "path": ["wso2", "pos", "checkout"]
            },
            "description": "El POS envía XML al WSO2. WSO2 lo transforma al SalesOrderCanonical (JSON) y dispara el SAGA en VentaPos."
          }
        }
      ]
    },
    {
      "name": "2. Orquestador SAGA - Ventas (POS y Web)",
      "item": [
        {
          "name": "Ventas POS Directo (Bypass WSO2)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ordenId\": \"VTA-001\",\n  \"canalOrigen\": \"POS\",\n  \"cliente\": {\n    \"numeroDocumento\": \"72019999\"\n  },\n  \"detalles\": [\n    {\n      \"codigoArticulo\": \"SKU-LAP-001\",\n      \"cantidad\": 1,\n      \"precioUnitario\": 3500.00\n    }\n  ],\n  \"pago\": {\n    \"metodo\": \"TARJETA_CREDITO\",\n    \"tokenTarjeta\": \"1111-visa-valido\",\n    \"montoTotal\": 3500.00\n  }\n}"
            },
            "url": {
              "raw": "http://localhost:8082/api/v1/ventas-pos/checkout",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8082",
              "path": ["api", "v1", "ventas-pos", "checkout"]
            }
          }
        },
        {
          "name": "Ventas Web (E-Commerce)",
          "request": {
            "method": "POST",
            "header": [
